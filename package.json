{
  "name": "book",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "prisma generate",
    "dev": "next dev",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "npm run prisma:migrate:deploy && next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:seed": "prisma db seed",
    "prisma:bootstrap-admin": "tsx prisma/bootstrap-admin.ts",
    "prisma:reset:dev": "prisma migrate reset --force && prisma db seed",
    "prisma:studio": "prisma studio",
    "icons:generate": "tsx scripts/generate-pwa-icons.ts",
    "test": "tsx --test src/**/*.test.ts",
    "pretypecheck": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "start:prod": "npm run start",
    "prisma:reset-admin-password": "tsx prisma/reset-admin-password.ts",
    "security:scan:secrets": "bash scripts/scan-secrets.sh",
    "security:scan:bundle": "node scripts/check-client-bundle-secrets.mjs"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "next": "15.5.14",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "postcss": "^8.5.8",
    "prisma": "6.19.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5"
  }
}
