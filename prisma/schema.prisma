generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum BookStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum BookFormat {
  DIGITAL
  PHYSICAL
}

enum FileKind {
  COVER_IMAGE
  EPUB
  PDF
  AUDIO
  SAMPLE
}

enum StorageProvider {
  LOCAL
  S3
  CLOUDFLARE_R2
}

enum OfferType {
  PURCHASE
  RENTAL
}

enum CurrencyCode {
  SYP
  USD
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MANUAL
  STRIPE
  SHAM_CASH
  SYRIATEL_CASH
}

enum PaymentAttemptStatus {
  PENDING
  SUBMITTED
  VERIFYING
  PAID
  FAILED
}

enum AccessGrantType {
  PURCHASE
  RENTAL
}

enum AccessGrantStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

model User {
  id                String            @id @default(cuid())
  email             String            @unique
  fullName          String?
  role              UserRole          @default(USER)
  isActive          Boolean           @default(true)
  passwordHash      String?
  orders            Order[]
  payments          Payment[]
  paymentAttempts   PaymentAttempt[]
  accessGrants      AccessGrant[]
  readingProgresses ReadingProgress[]
  wishlistItems     WishlistItem[]
  reviews           BookReview[]
  creatorProfile    CreatorProfile?
  createdBooks      Book[]            @relation("BookCreator")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([role])
}

model CreatorProfile {
  id          String   @id @default(cuid())
  userId       String   @unique
  slug         String   @unique
  displayName  String
  bio          String?
  avatarUrl    String?
  coverUrl     String?
  authorId     String?  @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  author       Author?  @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Author {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameAr    String
  nameEn    String?
  bioAr     String?
  bioEn     String?
  books     Book[]
  creatorProfile CreatorProfile?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameAr      String
  nameEn      String?
  description String?
  books       Book[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Book {
  id               String            @id @default(cuid())
  slug             String            @unique
  titleAr          String
  titleEn          String?
  descriptionAr    String?
  descriptionEn    String?
  metadata         Json?
  coverImageUrl    String?
  textContent      String?
  status           BookStatus        @default(DRAFT)
  format           BookFormat        @default(DIGITAL)
  publicationDate  DateTime?
  authorId         String
  categoryId       String
  creatorId        String?
  author           Author            @relation(fields: [authorId], references: [id], onDelete: Restrict)
  category         Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  creator          User?             @relation("BookCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  files            BookFile[]
  offers           BookOffer[]
  orderItems       OrderItem[]
  accessGrants     AccessGrant[]
  readingProgress  ReadingProgress[]
  wishlistItems    WishlistItem[]
  reviews          BookReview[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([status])
  @@index([format])
  @@index([authorId])
  @@index([categoryId])
  @@index([creatorId])
}

model BookFile {
  id                String          @id @default(cuid())
  bookId            String
  kind              FileKind
  storageProvider   StorageProvider @default(LOCAL)
  storageKey        String
  bucket            String?
  region            String?
  publicUrl         String?
  originalFileName  String?
  mimeType          String?
  sizeBytes         Int?
  checksum          String?
  metadata          Json?
  coverWidth        Int?
  coverHeight       Int?
  coverBlurDataUrl  String?
  epubVersion       String?
  epubPackagePath   String?
  pdfVersion        String?
  pdfPageCount      Int?
  isEncrypted       Boolean         @default(false)
  sortOrder         Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  book              Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, kind, sortOrder])
  @@index([bookId, kind])
}

model BookOffer {
  id          String       @id @default(cuid())
  bookId       String
  type         OfferType
  priceCents   Int
  currency     CurrencyCode @default(SYP)
  rentalDays   Int?
  isActive     Boolean      @default(true)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  book         Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]

  @@index([bookId, type, isActive])
  @@index([startsAt, endsAt])
}


model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId, createdAt])
  @@index([bookId])
}

model BookReview {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId, createdAt])
}

model Order {
  id            String       @id @default(cuid())
  userId        String
  status        OrderStatus  @default(PENDING)
  currency      CurrencyCode @default(SYP)
  subtotalCents Int
  totalCents    Int
  placedAt      DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  items         OrderItem[]
  payments      Payment[]
  paymentAttempts PaymentAttempt[]

  @@index([userId, status])
  @@index([createdAt])
}

model OrderItem {
  id            String      @id @default(cuid())
  orderId       String
  bookId        String
  offerId       String?
  titleSnapshot String
  offerType     OfferType
  unitPriceCents Int
  quantity      Int         @default(1)
  rentalDays    Int?
  createdAt     DateTime    @default(now())
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book          Book        @relation(fields: [bookId], references: [id], onDelete: Restrict)
  offer         BookOffer?  @relation(fields: [offerId], references: [id], onDelete: SetNull)
  accessGrants  AccessGrant[]

  @@index([orderId])
  @@index([bookId])
  @@index([offerId])
}

model Payment {
  id             String          @id @default(cuid())
  userId          String
  orderId         String
  provider        PaymentProvider
  providerRef     String?
  status          PaymentStatus  @default(PENDING)
  amountCents     Int
  currency        CurrencyCode   @default(SYP)
  metadata        Json?
  paidAt          DateTime?
  failedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  attempts        PaymentAttempt[]

  @@index([userId, createdAt])
  @@index([orderId, status])
  @@index([provider, providerRef])
}

model PaymentAttempt {
  id                String               @id @default(cuid())
  paymentId          String
  userId             String
  orderId            String
  provider           PaymentProvider
  status             PaymentAttemptStatus @default(PENDING)
  amountCents        Int
  currency           CurrencyCode         @default(SYP)
  providerReference  String?
  requestPayload     Json?
  responsePayload    Json?
  failureReason      String?
  verifiedAt         DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  payment            Payment              @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  user               User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  order              Order                @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([paymentId, createdAt])
  @@index([orderId, status])
  @@index([provider, providerReference])
}

model AccessGrant {
  id            String            @id @default(cuid())
  userId         String
  bookId         String
  orderItemId    String?
  type           AccessGrantType
  status         AccessGrantStatus @default(ACTIVE)
  startsAt       DateTime          @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  book           Book              @relation(fields: [bookId], references: [id], onDelete: Restrict)
  orderItem      OrderItem?        @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@index([userId, status, expiresAt])
  @@index([bookId])
  @@index([orderItemId])
}

model ReadingProgress {
  id              String   @id @default(cuid())
  userId          String
  bookId          String
  progressPercent Float    @default(0)
  locator         String?
  lastOpenedAt    DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book            Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId, updatedAt])
  @@index([bookId])
}
