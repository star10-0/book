generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Book {
  id          String   @id @default(cuid())
  titleAr     String
  slug        String   @unique
  description String?
  priceCents  Int
  rentalDays  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
