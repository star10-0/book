generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum AdminScope {
  SUPER_ADMIN
  PAYMENT_ADMIN
  BREAK_GLASS_PAYMENT_ADMIN
  SUPPORT_ADMIN
  CONTENT_ADMIN
}

enum BookStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum BookFormat {
  DIGITAL
  PHYSICAL
}

enum ContentAccessPolicy {
  PRIVATE
  PAID_ONLY
  PUBLIC_READ
  PUBLIC_DOWNLOAD
  PREVIEW_ONLY
}

enum FileKind {
  COVER_IMAGE
  EPUB
  PDF
  AUDIO
  SAMPLE
}

enum StorageProvider {
  LOCAL
  S3
  CLOUDFLARE_R2
}

enum OfferType {
  PURCHASE
  RENTAL
}

enum CurrencyCode {
  SYP
  USD
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MANUAL
  STRIPE
  SHAM_CASH
  SYRIATEL_CASH
}

enum PaymentAttemptStatus {
  PENDING
  SUBMITTED
  VERIFYING
  PAID
  FAILED
}



enum AdminAuditAction {
  REPORT_EXPORTED
  USER_BANNED
  USER_UNBANNED
  USER_FORCE_LOGOUT_ALL
  USER_FORCE_PASSWORD_RESET
  TRUSTED_DEVICE_REVOKED
  PAYMENT_RETRY_VERIFY
  PAYMENT_RECONCILE_BY_TX
  PAYMENT_FORCE_GRANT_ACCESS
  PAYMENT_TX_LOCK_RELEASED
  PROMO_CODE_MUTATION
  BOOK_MUTATION
  CURRICULUM_MUTATION
}

enum UserSecurityEventType {
  LOGIN_SUCCESS
  LOGIN_BLOCKED_UNTRUSTED_DEVICE
  TRUSTED_DEVICE_REGISTERED
  TRUSTED_DEVICE_REVOKED
  POLICY_ACCEPTED
  PASSWORD_RESET_REQUIRED
  FORCE_LOGOUT_ALL
  CONTENT_ACCESS_TOKEN_INVALID
  CONTENT_ACCESS_REPLAY_AFTER_REVOCATION
  CONTENT_ACCESS_MULTIPLE_DEVICE_ANOMALY
  SUSPICIOUS_ACCOUNT_ACTIVITY
}

enum AccessGrantType {
  PURCHASE
  RENTAL
}

enum AccessGrantStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum PromoCodeType {
  FREE
  PERCENT
  FIXED
}

enum PromoCodeAudience {
  PUBLIC
  INSTITUTION
  CREATOR
}

enum PromoCodeAppliesTo {
  ANY
  PURCHASE
  RENTAL
  PUBLISHING_FEE
}

enum PromoRedemptionStatus {
  APPLIED
  REDEEMED
  VOIDED
}

model User {
  id                String            @id @default(cuid())
  email             String            @unique
  fullName          String?
  role              UserRole          @default(USER)
  adminScopes       AdminScope[]      @default([])
  isActive          Boolean           @default(true)
  passwordHash      String?
  sessionVersion    Int               @default(0)
  orders            Order[]
  payments          Payment[]
  paymentAttempts   PaymentAttempt[]
  accessGrants      AccessGrant[]
  readingProgresses ReadingProgress[]
  readerAnnotations ReaderAnnotation[]
  wishlistItems     WishlistItem[]
  reviews           BookReview[]
  creatorProfile    CreatorProfile?
  createdBooks      Book[]            @relation("BookCreator")
  organizationId    String?
  organization      Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  promoRedemptions  PromoRedemption[]
  creatorPromoCodes PromoCode[]       @relation("PromoCodeCreator")
  createdPromoCodes PromoCode[]       @relation("PromoCodeCreatedBy")
  curriculumLevelBookLinks CurriculumLevelBook[] @relation("CurriculumLevelBookAddedByAdmin")
  trustedDevices      UserTrustedDevice[]
  securityEvents      UserSecurityEvent[]
  adminAuditLogs      AdminAuditLog[]      @relation("AdminAuditActor")
  targetedAuditLogs   AdminAuditLog[]      @relation("AdminAuditTargetUser")
  readingSessions     ReadingSession[]
  protectedAssetHandoffTickets ProtectedAssetHandoffTicket[]
  protectedAssetSessions       ProtectedAssetSession[]
  acceptedDevicePolicyAt DateTime?
  acceptedTermsVersion String?
  requirePasswordReset Boolean           @default(false)
  bannedReason         String?
  lastSeenAt           DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([role])
  @@index([organizationId])
  @@index([acceptedTermsVersion])
  @@index([lastSeenAt])
}

model Organization {
  id         String      @id @default(cuid())
  slug       String      @unique
  name       String
  isActive   Boolean     @default(true)
  users      User[]
  promoCodes PromoCode[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model CreatorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  slug        String   @unique
  displayName String
  bio         String?
  avatarUrl   String?
  coverUrl    String?
  authorId    String?  @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  author      Author?  @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Author {
  id             String          @id @default(cuid())
  slug           String          @unique
  nameAr         String
  nameEn         String?
  bioAr          String?
  bioEn          String?
  books          Book[]
  creatorProfile CreatorProfile?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  slug        String
  nameAr      String
  nameEn      String?
  description String?
  kind        String?
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  icon        String?
  coverImage  String?
  themeKey    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children    Category[] @relation("CategoryTree")
  books       Book[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentId, sortOrder])
  @@index([parentId, slug])
  @@unique([parentId, slug])
  @@index([isActive, sortOrder])
  @@index([kind, sortOrder])
}

model Book {
  id                  String              @id @default(cuid())
  slug                String              @unique
  titleAr             String
  titleEn             String?
  descriptionAr       String?
  descriptionEn       String?
  metadata            Json?
  coverImageUrl       String?
  textContent         String?
  contentAccessPolicy ContentAccessPolicy @default(PAID_ONLY)
  status              BookStatus          @default(DRAFT)
  format              BookFormat          @default(DIGITAL)
  publicationDate     DateTime?
  authorId            String
  categoryId          String
  creatorId           String?
  author              Author              @relation(fields: [authorId], references: [id], onDelete: Restrict)
  category            Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  creator             User?               @relation("BookCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  files               BookFile[]
  offers              BookOffer[]
  orderItems          OrderItem[]
  accessGrants        AccessGrant[]
  readingSessions     ReadingSession[]
  readingProgress     ReadingProgress[]
  readerAnnotations   ReaderAnnotation[]
  wishlistItems       WishlistItem[]
  reviews             BookReview[]
  curriculumLevelLinks CurriculumLevelBook[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([status])
  @@index([format])
  @@index([authorId])
  @@index([categoryId])
  @@index([creatorId])
}

model CurriculumLevel {
  id          String                @id @default(cuid())
  slug        String                @unique
  nameAr      String
  nameEn      String?
  description String?
  sortOrder   Int                   @default(0)
  isActive    Boolean               @default(true)
  books       CurriculumLevelBook[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([isActive, sortOrder])
  @@index([sortOrder])
}

model CurriculumLevelBook {
  id                String          @id @default(cuid())
  curriculumLevelId String
  bookId            String
  sortOrder         Int             @default(0)
  addedByAdminId    String
  curriculumLevel   CurriculumLevel @relation(fields: [curriculumLevelId], references: [id], onDelete: Cascade)
  book              Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  addedByAdmin      User            @relation("CurriculumLevelBookAddedByAdmin", fields: [addedByAdminId], references: [id], onDelete: Restrict)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([curriculumLevelId, bookId])
  @@index([curriculumLevelId, sortOrder])
  @@index([bookId])
  @@index([addedByAdminId])
  @@index([sortOrder])
}

model BookFile {
  id               String          @id @default(cuid())
  bookId           String
  kind             FileKind
  storageProvider  StorageProvider @default(LOCAL)
  storageKey       String
  bucket           String?
  region           String?
  publicUrl        String?
  originalFileName String?
  mimeType         String?
  sizeBytes        Int?
  checksum         String?
  metadata         Json?
  coverWidth       Int?
  coverHeight      Int?
  coverBlurDataUrl String?
  epubVersion      String?
  epubPackagePath  String?
  pdfVersion       String?
  pdfPageCount     Int?
  isEncrypted      Boolean         @default(false)
  sortOrder        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  book             Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  protectedAssetHandoffTickets ProtectedAssetHandoffTicket[]
  protectedAssetSessions       ProtectedAssetSession[]

  @@unique([bookId, kind, sortOrder])
  @@index([bookId, kind])
}

model BookOffer {
  id         String       @id @default(cuid())
  bookId     String
  type       OfferType
  priceCents Int
  currency   CurrencyCode @default(SYP)
  rentalDays Int?
  isActive   Boolean      @default(true)
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  book       Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([bookId, type, isActive])
  @@index([startsAt, endsAt])
  @@unique([bookId, type])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId, createdAt])
  @@index([bookId])
}

model BookReview {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId, createdAt])
}

model Order {
  id               String            @id @default(cuid())
  userId           String
  publicOrderNumber String            @unique
  status           OrderStatus       @default(PENDING)
  currency         CurrencyCode      @default(SYP)
  subtotalCents    Int
  totalCents       Int
  discountCents    Int               @default(0)
  promoCodeId      String?
  placedAt         DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  items            OrderItem[]
  payments         Payment[]
  paymentAttempts  PaymentAttempt[]
  promoCode        PromoCode?        @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  promoRedemptions PromoRedemption[]
  adminAuditLogs   AdminAuditLog[]

  @@index([userId, status])
  @@index([userId, status, updatedAt])
  @@index([createdAt])
  @@index([promoCodeId])
}

model OrderItem {
  id             String        @id @default(cuid())
  orderId        String
  bookId         String
  offerId        String?
  titleSnapshot  String
  offerType      OfferType
  unitPriceCents Int
  quantity       Int           @default(1)
  rentalDays     Int?
  createdAt      DateTime      @default(now())
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book           Book          @relation(fields: [bookId], references: [id], onDelete: Restrict)
  offer          BookOffer?    @relation(fields: [offerId], references: [id], onDelete: SetNull)
  accessGrants   AccessGrant[]

  @@index([orderId])
  @@index([bookId])
  @@index([offerId])
}

model Payment {
  id               String            @id @default(cuid())
  userId           String
  orderId          String
  provider         PaymentProvider
  providerRef      String?
  status           PaymentStatus     @default(PENDING)
  amountCents      Int
  currency         CurrencyCode      @default(SYP)
  metadata         Json?
  paidAt           DateTime?
  failedAt         DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  order            Order             @relation(fields: [orderId], references: [id], onDelete: Restrict)
  attempts         PaymentAttempt[]
  promoRedemptions PromoRedemption[]

  @@unique([provider, providerRef])
  @@index([userId, createdAt])
  @@index([orderId, status])
  @@index([provider, providerRef])
}

model PaymentAttempt {
  id                String               @id @default(cuid())
  paymentId         String
  userId            String
  publicPaymentReference String       @unique
  orderId           String
  provider          PaymentProvider
  status            PaymentAttemptStatus @default(PENDING)
  amountCents       Int
  currency          CurrencyCode         @default(SYP)
  providerReference String?
  transactionReference String?
  requestPayload    Json?
  responsePayload   Json?
  failureReason     String?
  verifiedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  payment           Payment              @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  user              User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  order             Order                @relation(fields: [orderId], references: [id], onDelete: Restrict)
  adminAuditLogs    AdminAuditLog[]

  @@unique([provider, providerReference])
  @@index([paymentId, createdAt])
  @@index([orderId, status])
  @@index([provider, providerReference])
  @@index([transactionReference, createdAt(sort: Desc)])
}

model PromoCode {
  id                 String             @id @default(cuid())
  code               String             @unique
  internalLabel      String?
  notes              String?
  type               PromoCodeType
  value              Int?
  currency           CurrencyCode?
  isActive           Boolean            @default(true)
  startsAt           DateTime?
  expiresAt          DateTime?
  maxTotalUses       Int?
  maxUsesPerUser     Int?
  minimumAmountCents Int?
  audience           PromoCodeAudience  @default(PUBLIC)
  appliesTo          PromoCodeAppliesTo @default(ANY)
  organizationId     String?
  creatorId          String?
  createdByUserId    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  organization       Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  creator            User?              @relation("PromoCodeCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  createdBy          User?              @relation("PromoCodeCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  orders             Order[]
  redemptions        PromoRedemption[]

  @@index([code, isActive])
  @@index([organizationId])
  @@index([creatorId])
  @@index([audience, appliesTo])
}

model PromoRedemption {
  id                 String                @id @default(cuid())
  promoCodeId        String
  userId             String
  orderId            String
  paymentId          String?
  discountCents      Int
  originalTotalCents Int
  finalTotalCents    Int
  status             PromoRedemptionStatus @default(APPLIED)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  redeemedAt         DateTime?
  promoCode          PromoCode             @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user               User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  order              Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment            Payment?              @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([promoCodeId, userId, orderId])
  @@index([promoCodeId, status])
  @@index([userId, status])
  @@index([orderId])
  @@index([paymentId])
}

model AccessGrant {
  id          String            @id @default(cuid())
  userId      String
  bookId      String
  orderItemId String?
  type        AccessGrantType
  status      AccessGrantStatus @default(ACTIVE)
  startsAt    DateTime          @default(now())
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  book        Book              @relation(fields: [bookId], references: [id], onDelete: Restrict)
  orderItem   OrderItem?        @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  readingSessions ReadingSession[]

  @@unique([userId, orderItemId, type])
  @@index([userId, status, expiresAt])
  @@index([bookId])
  @@index([orderItemId])
}

model ReadingSession {
  id            String   @id @default(cuid())
  accessGrantId String
  userId        String
  bookId        String
  openedAt      DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  graceEndsAt   DateTime?
  closedAt      DateTime?
  lastLocator   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  accessGrant   AccessGrant @relation(fields: [accessGrantId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  book          Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([accessGrantId, userId])
  @@index([userId, openedAt])
  @@index([accessGrantId, graceEndsAt, closedAt])
  @@index([bookId])
}

model ProtectedAssetHandoffTicket {
  id               String   @id @default(cuid())
  tokenHash        String   @unique
  fileId           String
  disposition      String
  userId           String?
  accessGrantId    String?
  readingSessionId String?
  watermarkText    String?
  expiresAt        DateTime
  redeemedAt       DateTime?
  createdAt        DateTime @default(now())
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  file             BookFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId, expiresAt])
  @@index([userId, expiresAt])
  @@index([expiresAt, redeemedAt])
}

model ProtectedAssetSession {
  id               String   @id @default(cuid())
  tokenHash        String   @unique
  fileId           String
  disposition      String
  userId           String?
  accessGrantId    String?
  readingSessionId String?
  watermarkText    String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  file             BookFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId, expiresAt])
  @@index([userId, expiresAt])
  @@index([expiresAt])
}



model UserTrustedDevice {
  id              String   @id @default(cuid())
  userId          String
  tokenHash       String
  label           String?
  userAgent       String?
  ipAddress       String?
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  isTrusted       Boolean  @default(true)
  isPrimary       Boolean  @default(false)
  revokedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tokenHash])
  @@index([userId, revokedAt])
  @@index([userId, isPrimary])
}

model UserSecurityEvent {
  id          String                @id @default(cuid())
  userId      String
  type        UserSecurityEventType
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime              @default(now())
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model AdminAuditLog {
  id               String           @id @default(cuid())
  actorAdminId     String
  targetUserId     String?
  paymentAttemptId String?
  orderId          String?
  action           AdminAuditAction
  reason           String?
  metadata         Json?
  createdAt        DateTime         @default(now())
  actorAdmin       User             @relation("AdminAuditActor", fields: [actorAdminId], references: [id], onDelete: Restrict)
  targetUser       User?            @relation("AdminAuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  paymentAttempt   PaymentAttempt?  @relation(fields: [paymentAttemptId], references: [id], onDelete: SetNull)
  order            Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([actorAdminId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([paymentAttemptId, createdAt])
  @@index([orderId, createdAt])
  @@index([action, createdAt])
}

model ReadingProgress {
  id              String    @id @default(cuid())
  userId          String
  bookId          String
  progressPercent Float     @default(0)
  locator         String?
  lastOpenedAt    DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  book            Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId, updatedAt])
  @@index([bookId])
}

enum ReaderAnnotationType {
  DRAWING
  NOTE
  BOOKMARK
}

model ReaderAnnotation {
  id        String               @id @default(cuid())
  userId    String
  bookId    String
  type      ReaderAnnotationType
  locator   String
  payload   Json?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book                 @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([userId, bookId, type])
  @@index([bookId, locator])
}
