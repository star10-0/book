# ----------------------------------------------------------------------------
# Core runtime configuration (required)
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/book"
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
NEXTAUTH_SECRET="replace-with-the-same-value-as-auth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Public canonical origin used by metadata, sitemap, robots, and JSON-LD.
# In production set this to your final HTTPS domain, e.g. https://book.example.com
APP_BASE_URL="http://localhost:3000"

# Optional override for local development only
NODE_ENV="development"

# ----------------------------------------------------------------------------
# Book asset storage provider
# ----------------------------------------------------------------------------
# local | s3 | r2
BOOK_STORAGE_PROVIDER="local"

# S3 / S3-compatible storage (required when BOOK_STORAGE_PROVIDER=s3|r2)
BOOK_STORAGE_S3_ACCESS_KEY_ID=
BOOK_STORAGE_S3_SECRET_ACCESS_KEY=
BOOK_STORAGE_S3_SESSION_TOKEN=
BOOK_STORAGE_S3_PUBLIC_BUCKET=
BOOK_STORAGE_S3_PRIVATE_BUCKET=
BOOK_STORAGE_S3_REGION=us-east-1
BOOK_STORAGE_S3_ENDPOINT=
BOOK_STORAGE_S3_FORCE_PATH_STYLE=false
BOOK_STORAGE_PUBLIC_BASE_URL=
BOOK_STORAGE_SIGNED_URL_EXPIRY_SECONDS=60


# ----------------------------------------------------------------------------
# Payment gateway behavior
# ----------------------------------------------------------------------------
# mock | live
PAYMENT_GATEWAY_MODE="mock"
# Comma-separated live providers: SHAM_CASH, SYRIATEL_CASH
PAYMENT_LIVE_PROVIDERS="SHAM_CASH"

# For development/test only. Ignored in production.
ALLOW_MOCK_PAYMENT_VERIFICATION="true"

# ----------------------------------------------------------------------------
# Sham Cash manual verification flow (required when PAYMENT_GATEWAY_MODE=live and provider is enabled)
# ----------------------------------------------------------------------------
SHAM_CASH_API_BASE_URL="https://api.shamcash.example"
SHAM_CASH_API_KEY="replace-with-sham-cash-api-key"
SHAM_CASH_DESTINATION_ACCOUNT="replace-with-sham-cash-destination-account"
SHAM_CASH_TIMEOUT_MS="10000"

# ----------------------------------------------------------------------------
# Syriatel Cash manual-transfer + find_tx verification flow
# (required when PAYMENT_GATEWAY_MODE=live and provider is enabled)
# ----------------------------------------------------------------------------
SYRIATEL_CASH_API_BASE_URL="https://api.syriatelcash.example"
SYRIATEL_CASH_API_KEY="replace-with-syriatel-cash-api-key"
SYRIATEL_CASH_DESTINATION_ACCOUNT="replace-with-syriatel-destination-account"
# Optional override for find transaction endpoint path (defaults to /find_tx)
SYRIATEL_CASH_FIND_TX_PATH="/find_tx"
SYRIATEL_CASH_TIMEOUT_MS="10000"

# Optional distributed rate limiting (Upstash Redis REST-compatible)
KV_REST_API_URL=
KV_REST_API_TOKEN=
