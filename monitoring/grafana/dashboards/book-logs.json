{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "logs",
      "title": "Application Logs",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": "Loki",
          "expr": "{compose_service=~\"app|migrate|db\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Logs per 5m",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum(count_over_time({compose_service='app', level='error'}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Warn Logs per 5m",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum(count_over_time({compose_service='app', level='warn'}[5m]))",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 40,
  "tags": ["book", "logs"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
