# Runtime
NODE_ENV=production
PORT=3000

# Public URL configuration
NEXTAUTH_URL=https://your-domain.example
APP_BASE_URL=https://your-domain.example

# Core application secrets
AUTH_SECRET=replace-with-a-random-32-char-min-secret
NEXTAUTH_SECRET=replace-with-the-same-value-as-auth-secret

# Database
DATABASE_URL=postgresql://book:book@db:5432/book

# Storage + payments
BOOK_STORAGE_PROVIDER=local

# S3 / S3-compatible storage (required when BOOK_STORAGE_PROVIDER=s3|r2)
BOOK_STORAGE_S3_ACCESS_KEY_ID=
BOOK_STORAGE_S3_SECRET_ACCESS_KEY=
BOOK_STORAGE_S3_SESSION_TOKEN=
BOOK_STORAGE_S3_PUBLIC_BUCKET=
BOOK_STORAGE_S3_PRIVATE_BUCKET=
BOOK_STORAGE_S3_REGION=us-east-1
BOOK_STORAGE_S3_ENDPOINT=
BOOK_STORAGE_S3_FORCE_PATH_STYLE=false
BOOK_STORAGE_PUBLIC_BASE_URL=
BOOK_STORAGE_SIGNED_URL_EXPIRY_SECONDS=60

PAYMENT_GATEWAY_MODE=live
# Comma-separated live providers: SHAM_CASH, SYRIATEL_CASH
PAYMENT_LIVE_PROVIDERS=SHAM_CASH
ALLOW_MOCK_PAYMENTS=false
ALLOW_MOCK_PAYMENT_VERIFICATION=false

# Required in production for distributed rate limits.
KV_REST_API_URL=https://example-redis.upstash.io
KV_REST_API_TOKEN=replace-with-upstash-token

# Sham Cash (required when PAYMENT_GATEWAY_MODE=live and SHAM_CASH is selected in PAYMENT_LIVE_PROVIDERS)
SHAM_CASH_API_BASE_URL=
SHAM_CASH_API_KEY=
SHAM_CASH_DESTINATION_ACCOUNT=
SHAM_CASH_TIMEOUT_MS=10000

# Syriatel Cash (required when PAYMENT_GATEWAY_MODE=live and SYRIATEL_CASH is selected in PAYMENT_LIVE_PROVIDERS)
SYRIATEL_CASH_API_BASE_URL=
SYRIATEL_CASH_API_KEY=
SYRIATEL_CASH_MERCHANT_ID=
SYRIATEL_CASH_DESTINATION_ACCOUNT=
SYRIATEL_CASH_CREATE_PAYMENT_PATH=/payments/create
SYRIATEL_CASH_VERIFY_PAYMENT_PATH=/payments/verify
SYRIATEL_CASH_TIMEOUT_MS=10000

# docker-compose.prod.yml host mount customizations (optional)
APP_PORT=3000
POSTGRES_DB=book
POSTGRES_USER=book
POSTGRES_PASSWORD=book
POSTGRES_DATA_PATH=./volumes/postgres-data
PUBLIC_UPLOADS_PATH=./volumes/public-uploads
PRIVATE_UPLOADS_PATH=./volumes/private-uploads

# Launch gating (keep strict for first public release)
# Keep PAYMENT_GATEWAY_MODE=mock in staging until end-to-end payment verification is complete.
# Switch to PAYMENT_GATEWAY_MODE=live only when callback URLs, merchant accounts, and alerting are confirmed.
